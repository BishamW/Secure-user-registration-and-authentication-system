{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile and security settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "country": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "passwordChangedAt": { "type": "string", "format": "date-time" },
        "lastPinVerifiedAt": { "type": "string", "format": "date-time" },
        "pinHash": { "type": "string" },
        "failedLoginAttempts": { "type": "integer" },
        "lockoutUntil": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "isVerified", "failedLoginAttempts"]
    },
    "PasswordHistory": {
      "title": "Password History",
      "description": "Tracks previous password hashes for the 1-year look-back rule.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "passwordHash": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "passwordHash", "createdAt"]
    },
    "SecurityLog": {
      "title": "Security Log",
      "description": "Audit log of security-related events.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["login", "failed_login", "password_change", "2fa_success", "2fa_failure", "signup"] },
        "details": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "failure"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "details", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/users/{userId}/passwordHistory/{historyId}": {
      "schema": "PasswordHistory",
      "description": "User's password history."
    },
    "/users/{userId}/securityLogs/{logId}": {
      "schema": "SecurityLog",
      "description": "User's security audit logs."
    }
  }
}
